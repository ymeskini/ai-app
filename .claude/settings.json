{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run format:write 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "npm run lint:fix 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npm run typecheck 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
