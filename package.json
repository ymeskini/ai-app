    "nanoid": "^5.1.7",
    "next": "^16.2.1",
    "next-auth": "5.0.0-beta.30",
    "postgres": "^3.4.7",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^9.0.3",
