{
  "name": "ai-app-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "eslint lint && tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push --force",
    "db:setup": "bash scripts/db-setup.sh",
    "db:seed": "jiti scripts/seed.ts",
    "rag:test": "jiti scripts/rag-test.ts",
    "db:studio": "drizzle-kit studio",
    "dev": "docker compose up -d --wait && next dev",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "test": "vitest run",
    "test:watch": "vitest",
    "evals": "evalite watch",
    "evals:promptfoo": "promptfoo eval -c evals/promptfooconfig.yaml --env-file=.env"
  },
  "dependencies": {
